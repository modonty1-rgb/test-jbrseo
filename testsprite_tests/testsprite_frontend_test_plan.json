  {
    "id": "TC018",
    "title": "Update General settings and verify public site reflects the change",
    "description": "Verifies an admin can update General settings, save successfully, and see the updated content on the public homepage.",
    "category": "Admin Dashboard and Settings",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /admin/login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username/email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/admin\""
      },
      {
        "type": "action",
        "description": "Click \"Settings\" in the dashboard navigation"
      },
      {
        "type": "action",
        "description": "Click \"General\" in the settings navigation"
      },
      {
        "type": "action",
        "description": "Fill \"Updated General Setting\" into a visible General settings text field (such as Site Name or Tagline)"
      },
      {
        "type": "action",
        "description": "Click the \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Saved\" is visible"
      },
      {
        "type": "action",
        "description": "Click the site/home link in the admin header (or any visible link that returns to the public site)"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Updated General Setting\" is visible"
      }
    ]
  },
